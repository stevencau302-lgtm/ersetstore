{
  "enabled": true,
  "name": "Auto Push on Save",
  "description": "Otomatis commit & push ke GitHub setiap ada perubahan file disimpan (trigger deploy Vercel)",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.ts",
      "*.tsx",
      "*.css",
      "*.html",
      "*.json",
      "*.sql",
      "*.md"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "powershell -ExecutionPolicy Bypass -File scripts/autopush.ps1",
    "timeout": 120
  }
}